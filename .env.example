# 调试模式
APP_DEBUG = true

# 服务端端口
SERVER_LISTEN = http://0.0.0.0:8888
# 同一源码启动多个本机实例时必须为每个实例指定独立 runtime/PID 目录。
APP_RUNTIME_PATH =

# 当前代理上传阶段的 Webman/Workerman 请求包上限：2GiB 业务文件 + 1MiB multipart 余量。
# 后续切换对象存储直传/分片后，应按控制面实际请求大小重新收紧该入口上限。
WEBMAN_MAX_PACKAGE_SIZE_BYTES = 2148532224

# 当前部署信任域，会写入租户 token 上下文
DEPLOYMENT_ID = b8im-local
APP_INFO_RATE_LIMIT_PER_MINUTE = 60

# OpenTelemetry Trace：应用只向内网 OTLP/HTTP Protobuf 端点上报。
# 长驻 worker 使用有界批处理队列；采集端故障时最多等待下方超时，不重试、不改变业务响应。
OTEL_TRACES_ENABLED = true
OTEL_SDK_DISABLED = false
OTEL_DEPLOYMENT_ENVIRONMENT = local
OTEL_SERVICE_NAME = b8im-server
OTEL_SERVICE_VERSION = dev
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT = http://otel-collector:4318/v1/traces
OTEL_EXPORTER_OTLP_TRACES_TIMEOUT = 250
OTEL_BSP_MAX_QUEUE_SIZE = 2048
OTEL_BSP_MAX_EXPORT_BATCH_SIZE = 128
OTEL_BSP_SCHEDULE_DELAY = 5000
# 本地/测试环境默认全量；SaaS 可调整为 0..1，且会继承上游 W3C 采样决策。
OTEL_TRACES_SAMPLER_ARG = 1.0

# appInfo schema v2 Ed25519 线路快照签名。私钥使用 base64url 编码的 32 字节 seed
# 或 64 字节 secret key；私钥只允许由运行环境注入，不能提交到仓库。
ROUTING_SIGNING_KID =
ROUTING_SIGNING_PRIVATE_KEY =

# 跨域请求的可信前端 Origin，逗号分隔，必须是精确 scheme + host + port。
# 不允许通配符。留空时所有带 Origin 的控制面跨域请求默认拒绝。
# 示例：https://admin.example.com,https://tenant.example.com,http://127.0.0.1:16888
SAIMULTI_CORS_ALLOWED_ORIGINS =
ROUTING_SNAPSHOT_TTL_SECONDS = 86400
ROUTING_STALE_TTL_SECONDS = 172800

# 生产必填；开发模式未配置时使用仅本机稳定的派生值
JWT_ACCESS_SECRET_KEY =
JWT_REFRESH_SECRET_KEY =
# Web 普通用户 access token 有效期（秒，服务端限制为 300..604800）
WEB_ACCESS_TOKEN_TTL_SECONDS = 7200
# Web 登录按 organization+account 与全局 IP 双维度原子限流
WEB_IM_LOGIN_ACCOUNT_LIMIT = 5
WEB_IM_LOGIN_IP_LIMIT = 30
WEB_IM_LOGIN_WINDOW_SECONDS = 300

# IM WebSocket 挑战凭证：生产环境必须配置至少 32 字节的独立随机密钥
IM_TOKEN_SECRET =
# IM 挑战凭证有效期（秒），实际有效期不会超过 Web access token 的剩余时间
IM_TOKEN_TTL_SECONDS = 300

# 数据库配置
DB_TYPE = mysql
DB_HOST = 127.0.0.1
DB_PORT = 3306
DB_NAME = nb8im
DB_USER = root
DB_PASSWORD = root
DB_PREFIX =
DB_CHARSET = utf8mb4
DB_COLLATION = utf8mb4_general_ci
# Server 容器启动时默认校验并幂等导入 665552 条地区编码。
RUN_AREA_CODE_INIT_ON_START = 1

# 缓存方式
CACHE_MODE = redis

# Redis配置
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASSWORD =
REDIS_DB = 0

# 模块系统
B8IM_SYSTEM_VERSION = 0.1.0
# 多个受控模块目录用英文逗号分隔；SDK announcement 示例始终内置扫描
SERVER_MODULE_PATHS =
MODULE_MIGRATION_ENVIRONMENT = default
MODULE_LIFECYCLE_LOCK_TTL_SECONDS = 900
MODULE_ACCESS_CACHE_TTL_SECONDS = 60
# 留空时敏感模块配置写入将失败关闭。生产环境请注入至少 32 字节的随机值（可使用 base64:<value>）。
MODULE_CONFIG_ENCRYPTION_KEY =
MODULE_EXPIRY_SCAN_INTERVAL_SECONDS = 60
MODULE_EXPIRY_SCAN_BATCH_SIZE = 200
MODULE_EXPIRY_LOCK_TTL_SECONDS = 55
MODULE_EXPIRY_TASK_LEASE_SECONDS = 1800
MODULE_EXPIRY_TASK_RETRY_BASE_DELAY_SECONDS = 5
MODULE_EXPIRY_TASK_RETRY_MAX_DELAY_SECONDS = 300
# 未确认上传对象的持久化清理扫描。
UPLOAD_CLEANUP_INTERVAL_SECONDS = 30
UPLOAD_CLEANUP_BATCH_SIZE = 25

# Search 消息投影消费者。入口默认关闭；只有稳定 event_id 的 IM 版本发布并完成
# Rabbit/Redis/MySQL 配置后才允许显式开启。该进程不消费实时队列 im.message.after。
SEARCH_CONSUMER_ENABLED = false
SEARCH_CONSUMER_RABBIT_HOST = 127.0.0.1
SEARCH_CONSUMER_RABBIT_PORT = 5672
SEARCH_CONSUMER_RABBIT_USER = guest
SEARCH_CONSUMER_RABBIT_PASSWORD = guest
SEARCH_CONSUMER_RABBIT_VHOST = /
SEARCH_CONSUMER_RABBIT_CONNECTION_TIMEOUT_SECONDS = 2.0
SEARCH_CONSUMER_RABBIT_READ_WRITE_TIMEOUT_SECONDS = 2.0
SEARCH_CONSUMER_RABBIT_CONFIRM_TIMEOUT_SECONDS = 2.0
SEARCH_CONSUMER_PREFETCH = 1
SEARCH_CONSUMER_POLL_INTERVAL_SECONDS = 0.25
# 每 tick 双重有界 drain：先达到消息数或 wall-clock deadline 即停止。
SEARCH_CONSUMER_MAX_MESSAGES_PER_TICK = 50
SEARCH_CONSUMER_MAX_TICK_DURATION_MS = 200
SEARCH_CONSUMER_INSTANCE_ID =
SEARCH_CONSUMER_HEARTBEAT_KEY = b8im:search:consumer:readiness
# 必须覆盖 Rabbit 连接/读写/confirm、poll interval 与单 tick 时限的三倍安全窗口。
SEARCH_CONSUMER_HEARTBEAT_TTL_SECONDS = 15

# Search 分片重建 worker。默认关闭即 fail-closed：Search 启用与已启用版本升级恢复都会失败并保留围栏。
# 发布/升级顺序必须先同时开启 consumer + rebuild 进程并确认两个 heartbeat ready，再执行模块迁移或启用。
SEARCH_REBUILD_ENABLED = false
SEARCH_REBUILD_POLL_INTERVAL_SECONDS = 0.5
SEARCH_REBUILD_BATCH_SIZE = 100
SEARCH_REBUILD_CLEANUP_BATCH_SIZE = 100
SEARCH_REBUILD_LEASE_SECONDS = 60
SEARCH_REBUILD_BARRIER_TIMEOUT_SECONDS = 300
SEARCH_REBUILD_RETRY_BASE_DELAY_SECONDS = 5
SEARCH_REBUILD_RETRY_MAX_DELAY_SECONDS = 300
SEARCH_REBUILD_MAX_RETRY_ATTEMPTS = 12
SEARCH_REBUILD_WORKER_ID =
SEARCH_REBUILD_HEARTBEAT_TTL_SECONDS = 120
