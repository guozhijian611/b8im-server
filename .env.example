# 调试模式
APP_DEBUG = true

# 服务端端口
SERVER_LISTEN = http://0.0.0.0:8888

# 当前部署信任域，会写入租户 token 上下文
DEPLOYMENT_ID = b8im-local

# 生产必填；开发模式未配置时使用仅本机稳定的派生值
JWT_ACCESS_SECRET_KEY =
JWT_REFRESH_SECRET_KEY =

# 数据库配置
DB_TYPE = mysql
DB_HOST = 127.0.0.1
DB_PORT = 3306
DB_NAME = nb8im
DB_USER = root
DB_PASSWORD = root
DB_PREFIX =
DB_CHARSET = utf8mb4
DB_COLLATION = utf8mb4_general_ci

# 缓存方式
CACHE_MODE = redis

# Redis配置
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASSWORD =
REDIS_DB = 0
