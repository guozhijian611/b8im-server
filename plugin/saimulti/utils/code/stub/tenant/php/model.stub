    public function search{{column.column_name | camel}}Attr($query, $value)
    {
        $query->where('{{column.column_name}}', 'like', '%'.$value.'%');
    }

{% endif %}
{% if column.is_query == 2 and column.query_type == 'in' %}
    /**
